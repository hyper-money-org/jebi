{
  "name": "term",
  "version": "0.1.0",
  "description": "A modern developer terminal",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder"
  },
  "build": {
    "appId": "com.jawahar.term",
    "productName": "term",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../core/term-core",
        "to": "term-core"
      },
      {
        "from": "../core/bin/llama-server",
        "to": "llama-server"
      },
      {
        "from": "../core/bin/libggml-base.dylib",
        "to": "libggml-base.dylib"
      },
      {
        "from": "../core/bin/libggml-base.0.dylib",
        "to": "libggml-base.0.dylib"
      },
      {
        "from": "../core/bin/libggml-blas.dylib",
        "to": "libggml-blas.dylib"
      },
      {
        "from": "../core/bin/libggml-blas.0.dylib",
        "to": "libggml-blas.0.dylib"
      },
      {
        "from": "../core/bin/libggml-cpu.dylib",
        "to": "libggml-cpu.dylib"
      },
      {
        "from": "../core/bin/libggml-cpu.0.dylib",
        "to": "libggml-cpu.0.dylib"
      },
      {
        "from": "../core/bin/libggml-metal.dylib",
        "to": "libggml-metal.dylib"
      },
      {
        "from": "../core/bin/libggml-metal.0.dylib",
        "to": "libggml-metal.0.dylib"
      },
      {
        "from": "../core/bin/libggml-rpc.dylib",
        "to": "libggml-rpc.dylib"
      },
      {
        "from": "../core/bin/libggml-rpc.0.dylib",
        "to": "libggml-rpc.0.dylib"
      },
      {
        "from": "../core/bin/libggml.dylib",
        "to": "libggml.dylib"
      },
      {
        "from": "../core/bin/libggml.0.dylib",
        "to": "libggml.0.dylib"
      },
      {
        "from": "../core/bin/libllama.dylib",
        "to": "libllama.dylib"
      },
      {
        "from": "../core/bin/libllama.0.dylib",
        "to": "libllama.0.dylib"
      },
      {
        "from": "../core/bin/libmtmd.dylib",
        "to": "libmtmd.dylib"
      },
      {
        "from": "../core/bin/libmtmd.0.dylib",
        "to": "libmtmd.0.dylib"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "playwright": "^1.59.1",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "highlight.js": "^11.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "tailwindcss": "^4.2.2"
  }
}
